{
  "plugins": [
    "remark-gfm",
    "remark-github-blockquote-alert",
    "remark-preset-lint-consistent",
    "remark-preset-lint-recommended",
    ["remark-lint-no-heading-punctuation", false],
    "remark-lint-no-trailing-spaces"
  ],
  "settings": {
    "bullet": "-",
    "emphasis": "_",
    "strong": "*",
    "listItemIndent": "one",
    "rule": "-"
  }
}
